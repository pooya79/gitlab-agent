# =====================================================================
# PRODUCTION env sample  (docker-compose-all.yml, behind Traefik)
# Copy to `.env.prod` and fill in. Differs from dev (.env.sample):
#   - Everything is ONE public origin (your domain) behind Traefik:
#       /api  -> backend container (internal port 8000, fixed in the Dockerfile)
#       /     -> frontend container (internal port 3000)
#   - So the browser/GitLab only ever see the domain — never a LAN IP/port.
# Run with:  docker compose --env-file .env.prod -f docker/docker-compose-all.yml up --build -d
# =====================================================================

# =====================================
# Public domain — the SINGLE origin everything is served from.
# Use https with a real, internet-reachable domain (required so GitLab's
# servers can reach the OAuth callback AND the bot webhooks).
# PUBLIC_BACKEND_URL builds the callback (.../api/v1/auth/gitlab/callback),
# the webhook URLs, and avatar URLs; FRONTEND_URL is where the backend
# redirects after OAuth. In prod these are the SAME domain.
# =====================================
PUBLIC_BACKEND_URL=https://gitlab-agent.example.com
FRONTEND_URL=https://gitlab-agent.example.com

# Leave NEXT_PUBLIC_BACKEND_URL unset → compose defaults it to "/" so the
# browser calls /api on the same origin. Only set it if the frontend is
# served from a DIFFERENT origin than the backend.
# NEXT_PUBLIC_BACKEND_URL=

# Public port Traefik listens on (map to 443 if you terminate TLS at Traefik).
PORT=80

# BACKEND_HOST / BACKEND_PORT are NOT used by the prod containers — the backend
# runs on the fixed internal port 8000 and Traefik routes /api to it. They only
# affect host_url when PUBLIC_BACKEND_URL is blank, which it must not be in prod.

# Extra host mapping injected into containers (only needed if your GitLab is
# reached by a hostname that doesn't resolve via normal DNS inside Docker).
HOST_VC_DOMAIN=gitlab.example.net
HOST_VC=10.0.0.10

TRAEFIK_DASHBOARD_PORT=8080


# =====================================
# Admin Account — used by `make create-admin` to seed the /admin login.
# CHANGE THESE. Use a strong password.
# =====================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong


# =====================================
# Security / Auth
# Generate a fresh SECRET_KEY, e.g.:  openssl rand -hex 32
# =====================================
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240


# =====================================
# Logging / Telemetry
# =====================================
LOGFIRE_TOKEN=pylf_v1_


# =====================================
# API Keys
# =====================================
OPENROUTER_API_KEY=sk-or


# =====================================
# MongoDB — set strong credentials; do NOT expose the port publicly in prod.
# =====================================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_OUT_PORT=27017
MONGODB_DATABASE=gitlab_agent
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=CHANGE_ME_strong_password


# =====================================
# GitLab (OPTIONAL — one-time seed only)
# Seeds the DB on first startup; afterwards manage GitLab settings in /admin
# (DB wins). Leave blank to configure entirely from the /admin panel.
# The OAuth application's Redirect URI in GitLab must be registered as:
#   ${PUBLIC_BACKEND_URL}/api/v1/auth/gitlab/callback
# =====================================
GITLAB_BASE=https://gitlab.example.net
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SSL_VERIFY=true
