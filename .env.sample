# =====================================
# Backend bind address — where uvicorn listens locally and what the frontend
# uses as its API base in `make dev`. BACKEND_HOST must include the scheme.
# Change BACKEND_PORT here and the dev server + frontend API base both follow.
# =====================================
BACKEND_HOST=http://localhost
BACKEND_PORT=8000

# =====================================
# Public backend URL — the URL GitLab must be able to REACH over the network.
# Used for the OAuth callback, the bot webhook URLs, and avatar URLs.
#   - Plain local dev (OAuth only): leave blank → derived as BACKEND_HOST:BACKEND_PORT.
#   - Dev WITH webhooks: set to your tunnel, e.g. https://your-id.ngrok.app
#     (GitLab's servers can't reach localhost, so webhooks need a public URL).
#   - Production: set to your real domain, e.g. https://gitlab-agent.example.com
# =====================================
PUBLIC_BACKEND_URL=

# Extra hosts (for Docker)
HOST_VC_DOMAIN=example.com
HOST_VC=192.168.1.2

TRAEFIK_DASHBOARD_PORT=8080


# =====================================
# Admin Account
# Defaults used by `make create-admin`, which creates/updates the admin user
# that signs into the /admin panel (username + password).
# =====================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin


# =====================================
# Security / Auth
# =====================================
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240


# =====================================
# Logging / Telemetry
# =====================================
LOGFIRE_TOKEN=pylf_v1_


# =====================================
# API Keys
# =====================================
OPENROUTER_API_KEY=sk-or


# =====================================
# MongoDB
# =====================================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_OUT_PORT=27017
MONGODB_DATABASE=gitlab_agent
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=example

# mongo-express web UI (dev only) — http://localhost:${MONGO_EXPRESS_OUT_PORT}
MONGO_EXPRESS_OUT_PORT=8081
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin


# =====================================
# GitLab (OPTIONAL — one-time seed)
# These only seed the database on first startup. Afterwards the GitLab settings
# are managed in the /admin panel and the DB values win. You can leave these
# blank and configure GitLab entirely from /admin.
# =====================================
GITLAB_BASE=https://example.net
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SSL_VERIFY=false


# =====================================
# URL Settings
# =====================================
FRONTEND_URL=http://localhost:3000

# Public backend URL exposed to the browser (Next.js).
# - `make dev` ignores this and derives it from BACKEND_HOST:BACKEND_PORT above.
# - The prod compose stack defaults this to "/" (frontend + backend share a host
#   behind Traefik). Only set it here if you serve the frontend standalone and
#   need to point it at an absolute backend URL.
# NEXT_PUBLIC_BACKEND_URL=
